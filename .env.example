# Owmee — environment variables
# Copy to .env and fill in YOUR_* values. .env is in .gitignore.

# ── Application ─────────────────────────────────────────────────────────
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=YOUR_JWT_SECRET_32_CHARS_OR_MORE

# ── Database ────────────────────────────────────────────────────────────
POSTGRES_USER=owmee
POSTGRES_PASSWORD=owmee_dev_password
POSTGRES_DB=owmee
DATABASE_URL=postgresql+asyncpg://owmee:owmee_dev_password@postgres:5432/owmee

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO ───────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
R2_BUCKET=owmee-media
R2_REGION=auto
R2_ACCESS_KEY=minioadmin
R2_SECRET_KEY=minioadmin

# Internal endpoint (server-side, inside Docker)
R2_INTERNAL_ENDPOINT=http://minio:9000

# Public endpoint (baked into presigned URLs the mobile app uses)
# Replace YOUR_LAN_IP with your dev machine's actual LAN IP.
# macOS: ifconfig | grep "inet " | grep -v 127.0.0.1
# Linux: hostname -I | awk '{print $1}'
R2_PUBLIC_ENDPOINT=http://YOUR_LAN_IP:9000

# ── Temporal ───────────────────────────────────────────────────────────
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default

# ── Gemini ─────────────────────────────────────────────────────────────
# Free tier: 20 vision calls/day on gemini-2.5-flash
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_TEXT_MODEL=gemini-2.0-flash-lite

# ── KYC providers (mocked in dev) ──────────────────────────────────────
KYC_PROVIDER=mock
KYC_API_KEY=
KYC_API_SECRET=

# ── Payment partner (mocked in dev) ────────────────────────────────────
PAYMENT_PROVIDER=mock
PAYMENT_API_KEY=
PAYMENT_API_SECRET=

# ── Notifications ──────────────────────────────────────────────────────
FCM_SERVER_KEY=
SMS_PROVIDER=mock
SMS_API_KEY=

# ── Feature flags ──────────────────────────────────────────────────────
ENABLE_AI_LISTING=true
ENABLE_FIELD_EXECUTIVE=false
ENABLE_COMMUNITY=false

# ── Dev conveniences ───────────────────────────────────────────────────
DEV_OTP_BYPASS=true
DEV_KYC_BYPASS=true
DEV_FIXED_OTP=123456
