# ── Environment ────────────────────────────────────────────────────────────────
ENV=development

# ── Database ────────────────────────────────────────────────────────────────────
# Local dev: set automatically by docker-compose
# Production (Supabase): postgresql+asyncpg://USER:PASSWORD@db.PROJECT.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://owmee:owmee_dev_password@localhost:5432/owmee
SYNC_DATABASE_URL=postgresql://owmee:owmee_dev_password@localhost:5432/owmee

# ── Redis ────────────────────────────────────────────────────────────────────────
# Local dev: redis://:owmee_redis_password@localhost:6379/0
# Production (Upstash): rediss://default:TOKEN@HOST:PORT
REDIS_URL=redis://:owmee_redis_password@localhost:6379/0

# ── Temporal ────────────────────────────────────────────────────────────────────
# Local dev: localhost:7233
# Production (Temporal Cloud): NAMESPACE.tmprl.cloud:7233
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
# Temporal Cloud (production only — leave blank for local dev)
TEMPORAL_API_KEY=

# ── Cloudflare R2 ────────────────────────────────────────────────────────────────
# Local dev: MinIO endpoint
# Production: https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ENDPOINT=http://localhost:9000
R2_BUCKET=owmee-media
R2_EVIDENCE_BUCKET=owmee-evidence
R2_ACCESS_KEY=owmee_minio_user
R2_SECRET_KEY=owmee_minio_password
# Cloudflare R2 public CDN URL (set after bucket is created)
R2_PUBLIC_URL=http://localhost:9000/owmee-media

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── App secret ────────────────────────────────────────────────────────────────
SECRET_KEY=dev_secret_key_change_in_production_use_openssl_rand

# ── KYC partner (Digio / Karza / Signzy) ────────────────────────────────────────
KYC_PARTNER=digio
KYC_PARTNER_API_KEY=
KYC_PARTNER_BASE_URL=https://api.digio.in
KYC_WEBHOOK_SECRET=

# ── Payment Aggregator (Razorpay) ────────────────────────────────────────────────
PA_PROVIDER=razorpay
PA_KEY_ID=
PA_KEY_SECRET=
PA_WEBHOOK_SECRET=

# ── SMS (DLT-registered Transactional SMS) ────────────────────────────────────────
SMS_PROVIDER=msg91
SMS_API_KEY=
SMS_SENDER_ID=OWMAPP
SMS_DLT_ENTITY_ID=

# ── Push notifications ────────────────────────────────────────────────────────────
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=

# ── CORS ────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Rate limiting ────────────────────────────────────────────────────────────────
OTP_RATE_LIMIT_PER_HOUR=3
OTP_MAX_ATTEMPTS=5

# ── Ops / alerting ────────────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
