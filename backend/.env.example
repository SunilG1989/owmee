# ── Owmee Backend Configuration ──────────────────────────────────────────────
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── Environment ──────────────────────────────────────────────────────────────
ENV=development  # development | production

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://owmee:owmee_dev_password@postgres:5432/owmee
SYNC_DATABASE_URL=postgresql://owmee:owmee_dev_password@postgres:5432/owmee

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:owmee_redis_password@redis:6379/0

# ── Temporal ──────────────────────────────────────────────────────────────────
TEMPORAL_HOST=temporal:7233          # local dev
# TEMPORAL_HOST=your-namespace.tmprl.cloud:7233  # Temporal Cloud
TEMPORAL_NAMESPACE=default
TEMPORAL_API_KEY=                    # Temporal Cloud API key (leave empty for local)

# ── JWT / Security ────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem
SECRET_KEY=change_me_in_production_use_secrets_module

# ── Object Storage (Cloudflare R2 or MinIO) ───────────────────────────────────
# Dev: MinIO (local Docker container)
R2_ENDPOINT=http://minio:9000
R2_BUCKET=owmee-media
R2_EVIDENCE_BUCKET=owmee-evidence
R2_ACCESS_KEY=owmee_minio_user
R2_SECRET_KEY=owmee_minio_password
R2_PUBLIC_URL=http://localhost:9000  # CDN URL in production

# Production: Cloudflare R2
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_BUCKET=owmee-media
# R2_EVIDENCE_BUCKET=owmee-evidence
# R2_ACCESS_KEY=<R2_ACCESS_KEY_ID>
# R2_SECRET_KEY=<R2_SECRET_ACCESS_KEY>
# R2_PUBLIC_URL=https://media.owmee.in

# ── SMS OTP (production only) ─────────────────────────────────────────────────
SMS_PROVIDER=msg91         # msg91 | gupshup | (blank = dev bypass)
SMS_API_KEY=               # MSG91: authkey, Gupshup: userid
SMS_SENDER_ID=OWMAPP       # 6-char DLT-registered sender ID
SMS_DLT_ENTITY_ID=         # DLT entity ID from TRAI portal
# MSG91: also set the template_id here
# Gupshup: also set password (same as userid for basic auth)

# ── KYC Partner (Digio / Karza / Signzy / IDfy) ──────────────────────────────
KYC_PARTNER=digio          # digio | karza | signzy | idfy | (blank = dev stub)
KYC_PARTNER_API_KEY=       # Partner API key
KYC_PARTNER_BASE_URL=https://ext.digio.in:444
KYC_WEBHOOK_SECRET=        # Webhook signature secret for partner callbacks

# ── Payment Aggregator (Razorpay) ─────────────────────────────────────────────
PA_PROVIDER=razorpay       # razorpay | cashfree | payu | (blank = dev stub)
PA_KEY_ID=                 # Razorpay key_id (rzp_test_* or rzp_live_*)
PA_KEY_SECRET=             # Razorpay key_secret
PA_WEBHOOK_SECRET=         # Razorpay webhook signature secret

# ── Push Notifications (FCM) ──────────────────────────────────────────────────
FCM_SERVER_KEY=            # Firebase Cloud Messaging server key
# Get from: Firebase Console → Project Settings → Cloud Messaging → Server key
# APNs (iOS, not needed for Android-only launch)
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_KEY_PATH=/app/keys/apns_key.p8

# ── Chat (Stream Chat) ────────────────────────────────────────────────────────
STREAM_API_KEY=            # From getstream.io dashboard
STREAM_API_SECRET=         # From getstream.io dashboard

# ── Logistics ─────────────────────────────────────────────────────────────────
# SHIPROCKET_EMAIL=
# SHIPROCKET_PASSWORD=
# SHIPROCKET_WEBHOOK_TOKEN=

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=                # Sentry DSN for error tracking (optional)
LOG_LEVEL=INFO
APP_BASE_URL=http://localhost:8000

# ── Rate limiting ─────────────────────────────────────────────────────────────
OTP_RATE_LIMIT_PER_HOUR=3
OTP_MAX_ATTEMPTS=5
